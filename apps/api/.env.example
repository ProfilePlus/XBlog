DATABASE_URL=postgresql://xblog:change-me@127.0.0.1:5433/xblog?schema=public
XBLOG_STORE_DRIVER=prisma
API_HOST=127.0.0.1
API_PORT=4000
ADMIN_ORIGIN=http://127.0.0.1:3001
WEB_ORIGIN=http://127.0.0.1:3000
API_BASE_URL=http://127.0.0.1:4000
SESSION_COOKIE_NAME=xblog_admin_session

# local | s3
OBJECT_STORAGE_DRIVER=local

# generic | aws | r2 | minio
OBJECT_STORAGE_S3_PROVIDER=generic

# 对外公开读取资源时使用的基础地址。R2 这类 provider 必填。
OBJECT_STORAGE_PUBLIC_BASE_URL=

# 如果接 AWS S3，请填写真实 region，例如 ap-southeast-1。
OBJECT_STORAGE_S3_REGION=auto

# minio / r2 / generic 必填；aws 可选。
OBJECT_STORAGE_S3_ENDPOINT=
OBJECT_STORAGE_S3_BUCKET=
OBJECT_STORAGE_S3_ACCESS_KEY_ID=
OBJECT_STORAGE_S3_SECRET_ACCESS_KEY=
OBJECT_STORAGE_S3_FORCE_PATH_STYLE=false

# 仅本地文件系统 presign 上传链路会用到。
UPLOAD_SIGNING_SECRET=change-me
UPLOAD_MAX_BYTES=8388608
