DATABASE_URL=postgresql://xblog:change-me@127.0.0.1:5432/xblog?schema=public
XBLOG_STORE_DRIVER=prisma

API_HOST=127.0.0.1
API_PORT=4000
ADMIN_ORIGIN=https://admin.xblog.example.com
WEB_ORIGIN=https://xblog.example.com
API_BASE_URL=https://admin.xblog.example.com/api
SESSION_COOKIE_NAME=xblog_admin_session

# 公网部署下继续使用本机 MinIO 的 S3 兼容能力。
OBJECT_STORAGE_DRIVER=s3
OBJECT_STORAGE_S3_PROVIDER=minio
OBJECT_STORAGE_PUBLIC_BASE_URL=https://assets.xblog.example.com/xblog-assets
OBJECT_STORAGE_S3_REGION=auto
OBJECT_STORAGE_S3_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_S3_BUCKET=xblog-assets
OBJECT_STORAGE_S3_ACCESS_KEY_ID=change-me
OBJECT_STORAGE_S3_SECRET_ACCESS_KEY=change-me
OBJECT_STORAGE_S3_FORCE_PATH_STYLE=true

UPLOAD_SIGNING_SECRET=change-me
UPLOAD_MAX_BYTES=8388608
