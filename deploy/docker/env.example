# Global versioning
XBLOG_VERSION=20260319-1

# Image names used by the offline release process.
XBLOG_WEB_IMAGE=xblog-web
XBLOG_ADMIN_IMAGE=xblog-admin
XBLOG_API_IMAGE=xblog-api
XBLOG_CADDY_IMAGE=xblog-caddy
XBLOG_POSTGRES_IMAGE=postgres:16
XBLOG_MINIO_IMAGE=minio/minio:latest

# Compose project names for blue-green deployment.
XBLOG_PROJECT_BLUE=xblog-blue
XBLOG_PROJECT_GREEN=xblog-green

# Public domain settings.
XBLOG_BASE_DOMAIN=example.com
XBLOG_ACME_EMAIL=admin@example.com
XBLOG_ADMIN_BASIC_AUTH_USER=editorial
XBLOG_ADMIN_BASIC_AUTH_HASH=replace-with-bcrypt-hash

# Runtime service URLs.
WEB_ORIGIN=https://xblog.example.com
ADMIN_ORIGIN=https://admin.xblog.example.com
API_BASE_URL=https://admin.xblog.example.com/api
OBJECT_STORAGE_PUBLIC_BASE_URL=https://assets.xblog.example.com/xblog-assets

# Database and object storage.
DATABASE_URL=postgresql://xblog:change-me@postgres:5432/xblog?schema=public
POSTGRES_DB=xblog
POSTGRES_USER=xblog
POSTGRES_PASSWORD=change-me
MINIO_ROOT_USER=xblogminio
MINIO_ROOT_PASSWORD=change-me
OBJECT_STORAGE_S3_REGION=auto
OBJECT_STORAGE_S3_ENDPOINT=http://minio:9000
OBJECT_STORAGE_S3_BUCKET=xblog-assets
OBJECT_STORAGE_S3_ACCESS_KEY_ID=change-me
OBJECT_STORAGE_S3_SECRET_ACCESS_KEY=change-me
OBJECT_STORAGE_S3_FORCE_PATH_STYLE=true

