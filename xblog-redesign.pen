                  "fill": "#666666",
                  "content": "Search",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "500"
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "mM7ej",
          "name": "Article Hero",
          "width": 672,
          "layout": "vertical",
          "gap": 20,
          "padding": [
            120,
            0,
            80,
            0
          ],
          "alignItems": "center",
          "children": [
            {
              "type": "text",
              "id": "LcFJe",
              "fill": "#888888",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Design as choreography instead of composition",
              "textAlign": "center",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "500",
              "letterSpacing": 2
            },
            {
              "type": "text",
              "id": "0qj5C",
              "fill": "#151515",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "What Screens Want",
              "lineHeight": 1.1,
              "textAlign": "center",
              "fontFamily": "Playfair Display",
              "fontSize": 56
            },
            {
              "type": "text",
              "id": "aG6Sk",
              "fill": "#888888",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "November 14, 2013",
              "textAlign": "center",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "EIRVW",
          "name": "Article Body",
          "width": 672,
          "layout": "vertical",
          "gap": 28,
          "padding": [
            0,
            0,
            80,
            0
          ],
          "children": [
            {
              "type": "text",
              "id": "cl9Y1",
              "name": "p1",
              "fill": "#151515",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "I've been thinking a lot about what makes a good web experience. The web is a unique medium with its own constraints and possibilities. It's not print, and it's not television. It has its own grain.",
              "lineHeight": 1.6,
              "fontFamily": "Newsreader",
              "fontSize": 18,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "nR9LO",
              "name": "p2",
              "fill": "#151515",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "When we work with the web's grain, we create experiences that are fast, accessible, and resilient. When we work against it, we create fragile experiences that break easily and exclude people.",
              "lineHeight": 1.6,
              "fontFamily": "Newsreader",
              "fontSize": 18,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "suaPl",
              "name": "h2Wrap",
              "width": "fill_container",
              "layout": "vertical",
              "padding": [
                20,
                0,
                0,
                0
              ],
              "children": [
                {
                  "type": "text",
                  "id": "GhoMO",
                  "fill": "#151515",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "The Web's Constraints",
                  "lineHeight": 1.2,
                  "fontFamily": "Playfair Display",
                  "fontSize": 32
                }
              ]
            },
            {
              "type": "text",
              "id": "E2A4o",
              "name": "p3",
              "fill": "#151515",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "The web is fundamentally about documents and links. It's a network of interconnected information. This is its superpower, but also its constraint. We can't control how people access our content — they might use a phone, a tablet, a desktop, or a screen reader.",
              "lineHeight": 1.6,
              "fontFamily": "Newsreader",
              "fontSize": 18,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "uFuGx",
              "name": "p4",
              "fill": "#151515",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "This uncertainty is uncomfortable for designers who come from print, where you control every pixel. But it's also liberating. Instead of pixel-perfect layouts, we design systems that adapt.",
              "lineHeight": 1.6,
              "fontFamily": "Newsreader",
              "fontSize": 18,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "JcLQM",
              "name": "h3Wrap",
              "width": "fill_container",
              "layout": "vertical",
              "padding": [
                20,
                0,
                0,
                0
              ],
              "children": [
                {
                  "type": "text",
                  "id": "n9Hpu",
                  "fill": "#151515",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Designing with the Grain",
                  "lineHeight": 1.2,
                  "fontFamily": "Playfair Display",
                  "fontSize": 32
                }
              ]
            },
            {
              "type": "text",
              "id": "mezDO",
              "name": "p5",
              "fill": "#151515",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Working with the web's grain means embracing its fluidity. It means using semantic HTML, progressive enhancement, and responsive design. It means thinking about performance, accessibility, and resilience from the start.",
              "lineHeight": 1.6,
              "fontFamily": "Newsreader",
              "fontSize": 18,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "UicnW",
              "name": "p6",
              "fill": "#151515",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "The best web experiences feel effortless. They load quickly, work everywhere, and get out of the way. They respect the user's preferences and adapt to their context. This is what screens want.",
              "lineHeight": 1.6,
              "fontFamily": "Newsreader",
              "fontSize": 18,
              "fontWeight": "normal"
            }
          ]
        },
